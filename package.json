{
  "name": "social-media-manager",
  "version": "1.0.0",
  "description": "Minimal Express.js app with X (Twitter) API v2 integration",
  "main": "src/app.js",
  "keywords": [
    "express",
    "ejs",
    "twitter",
    "x"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.1",
    "pg": "^8.11.3",
    "resend": "^6.9.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "nodemon": "^3.0.2"
  },
  "scripts": {
    "start": "NODE_ENV=production node src/app.js",
    "dev": "npm run migrate && npm run dev:server",
    "dev:server": "nodemon src/app.js",
    "dev:vite": "cd mediaflow && npm run dev",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev:vite\"",
    "watch": "nodemon src/app.js",
    "migrate": "node src/db/migrate.js",
    "setup": "cd mediaflow && bun install && bun run build && cd .. && npm install && npm run migrate && npm start"
  }
}